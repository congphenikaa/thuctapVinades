<!-- BẮT ĐẦU: KHỐI FOOTER BÁO ĐẦU TƯ (ĐỘNG TỪ CSDL) -->
<footer class="bdt-footer">
    <div class="container">
        <div class="row">
            <!-- Cột Trái (Cột 1): Thông tin Tòa soạn & Liên hệ (Chiếm phần lớn diện tích) -->
            <div class="col-xs-24 col-sm-16 col-md-17 bdt-footer-col">
                <a href="{THEME_SITE_HREF}" class="bdt-footer-logo" style="display: block; margin-bottom: 20px;">
                    <img src="{LOGO_SRC}" alt="{SITE_NAME}" style="max-height: 50px;">
                </a>
                <div class="bdt-footer-info" style="color: #444; font-size: 13px; line-height: 1.6;">
                    [FOOTER_COL_1]
                </div>
            </div>
            
            <!-- Cột Phải (Cột 2): Đường dây nóng & Quảng cáo (Nằm ở góc đối diện) -->
            <div class="col-xs-24 col-sm-8 col-md-7 bdt-footer-col text-right bdt-footer-right-area">
                [FOOTER_COL_2]
            </div>
        </div>
    </div>
    
    <!-- Khối Bản quyền dưới cùng -->
    <div class="bdt-footer-bottom">
        <div class="container">
            <div class="row">
                <div class="col-xs-24" style="text-align: center;">
                    <p style="margin: 0; padding: 10px 0; color: #ccc; font-size: 13px;">
                        &copy; Bản quyền thuộc về <strong>{SITE_NAME}</strong>. Cấm sao chép dưới mọi hình thức nếu không có sự chấp thuận bằng văn bản.
                    </p>
                </div>
            </div>
        </div>
    </div>
</footer>
<!-- KẾT THÚC: KHỐI FOOTER -->